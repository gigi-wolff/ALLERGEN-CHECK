body {
  background-image: url(<%= asset_path 'background-1.jpg' %>);
  background-size:auto 100% no-repeat;
  /* background-color and background-blend-mode impact opacity */
  background-color: rgba(255, 255, 255, .8) !important;
  background-blend-mode: color;
}

#panel,
#show-panel {
  display: block;
  margin-left: 2%;
  float: left;
}

#panel {
  height: 325px; /* panel-body height + panel-heading height = panel-height */
  width: 30%;
  margin-bottom: 2%;
  box-shadow: 4px 4px 1px 4px rgba(0, 0, 0, 0.3)
}

#show-panel {
  width: 100%;
  margin-top: 5%;
  margin-bottom: 5%;
  box-shadow: 2px 2px 1px 2px rgba(0, 0, 0, 0.3)
}

#index-panel-heading,
#show-panel-heading {
  padding: 0px 0px;
  background-color: #c8d7e4;
  position: relative;
  font-size: 1.6rem;
  font-weight: bold;
  text-align: center;
}

#index-panel-heading {
  line-height: 100px;
  height: 100px; /* panel-body height + panel-heading height = panel-height */
}

#show-panel-heading {
  line-height: normal;
  height: fit-content;
}

#index-panel-button {
  white-space: normal; /* make text in button wrap */
}

#panel-body,
#show-panel-body {
  background-color: #e4edf5;
  text-align: center;
}

#panel-body {
  height: 225px; /* panel-body height + panel-heading height = panel-height */
  overflow-y:auto;
}

#show-panel-body { 
  height: auto;
  padding-top: 15px;
  padding-bottom: 15px;
}

#shrink {
  /*
  -webkit-transform:scale(0.8);
  -moz-transform:scale(0.8);
  -ms-transform:scale(0.8);
  transform:scale(0.8);
  */
  display: inline-grid;
  margin: 1%;

}

.btn {
  border: 1px solid;
  border-color: #3d505f !important;
}

.btn-primary {
  background-color: #657c8e  !important; 
  border-color: #586c7b !important;
}

.btn-primary:hover {
  color: #fff;
  background-color: #3d5060 !important;
  border-color: #222635 !important;
}

/*------------------*/
@media (max-width: 768px) {

  #panel {  
    width: 40%;
    float: left;
  }

}